# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only: cron, admin, seed, en voor het lezen van daily_state + aanmaken auto-missies
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: for `npm run db:types` (short ref from dashboard URL .../project/<ref>)
# SUPABASE_PROJECT_REF=vypjjwmdzuakswyrzoxd

# App
NEXT_PUBLIC_APP_VERSION=1.0.0

# Assistant: set to true in development/staging; leave false in production until Assistant is GA.
# NEXT_PUBLIC_ASSISTANT_ENABLED=false

# Optional: Vercel cron secret (to secure cron routes)
CRON_SECRET=your-random-secret

# Optional: Web Push (for notifications in Settings). Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
# VAPID_PRIVATE_KEY=your-private-key

# Optional: Google Calendar (Phase 8 – read-only sync). Create OAuth 2.0 credentials in Google Cloud Console.
# Add redirect URI: https://your-domain.com/api/auth/google/callback (and http://localhost:3000/api/auth/google/callback for dev)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: App URL for OAuth redirects and PWA start URL (so reopening from home screen works on mobile)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Optional: App reminder emails (morning/evening digest, weekly). Resend: in dev RESEND_API_KEY alone is enough; with domain add EMAIL_FROM.
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=NEUROHQ <no-reply@yourdomain.com>

# Optional: One-time test of daily emails. GET /api/test/daily-emails with Authorization: Bearer <this> (when not in dev)
# TEST_EMAIL_SECRET=your-random-secret

# Optional: Sentry
# NEXT_PUBLIC_SENTRY_DSN=
